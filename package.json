{
  "name": "dotclaudemd",
  "version": "0.3.0",
  "description": "CLAUDE.md Template Registry CLI — scaffold, lint, and health-check your CLAUDE.md files",
  "type": "module",
  "bin": {
    "dotclaudemd": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claudemd",
    "template",
    "scaffold",
    "lint",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.0.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "gray-matter": "^4.0.3",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
